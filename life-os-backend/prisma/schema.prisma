generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  password          String
  fullName          String?            @map("full_name")
  preferences       Json?              @default("{}")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  currentStreak     Int                @default(0) @map("current_streak")
  longestStreak     Int                @default(0) @map("longest_streak")
  lastActiveDate    DateTime?          @map("last_active_date")
  xp                Int                @default(0)
  level             Int                @default(1)
  activityLogs      ActivityLog[]
  dictationAttempts DictationAttempt[]
  dictations        Dictation[]
  learningItems     LearningItem[]
  resources         Resource[]
  tasks             Task[]
  progress          UserProgress[]
  Insight           Insight[]
  transactions      Transaction[]
  financeCategories FinanceCategory[]
  budgets           Budget[]
  decks             Deck[]
  goals             Goal[]
  dailyQuests       DailyQuest[]
  badges            UserBadge[]
  conversations     Conversation[]

  @@map("users")
}

model Resource {
  id            String         @id @default(uuid())
  userId        String         @map("user_id")
  title         String
  type          ResourceType   @default(TEXT)
  filePath      String?        @map("file_path")
  rawContent    String?        @map("raw_content")
  aiMetadata    Json?          @default("{}") @map("ai_metadata")
  createdAt     DateTime       @default(now()) @map("created_at")
  dictations    Dictation[]
  learningItems LearningItem[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks         Task[]

  @@map("resources")
}

model LearningItem {
  id                String             @id @default(uuid())
  resourceId        String?            @map("resource_id")
  term              String
  type              ItemType           @default(VOCABULARY)
  definition        String?
  exampleSentence   String?            @map("example_sentence")
  extraInfo         Json?              @default("{}") @map("extra_info")
  createdAt         DateTime           @default(now()) @map("created_at")
  userId            String?            @map("user_id")
  deckId            String?            @map("deck_id")
  dictationAttempts DictationAttempt[]
  resource          Resource?          @relation(fields: [resourceId], references: [id])
  user              User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck              Deck?              @relation(fields: [deckId], references: [id], onDelete: SetNull)
  progress          UserProgress[]

  @@index([term])
  @@map("learning_items")
}

model Dictation {
  id         String             @id @default(uuid())
  userId     String             @map("user_id")
  resourceId String?            @map("resource_id")
  title      String
  audioUrl   String             @map("audio_url")
  transcript String
  sentences  Json               @default("[]")
  vocabulary Json?
  summary    String?
  sourceType String             @default("upload") @map("source_type")
  sourceUrl  String?            @map("source_url")
  duration   Int?
  difficulty String             @default("medium")
  language   String             @default("en")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")
  category   String             @default("General")
  tags       String[]           @default([])
  attempts   DictationAttempt[]
  resource   Resource?          @relation(fields: [resourceId], references: [id])
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("dictations")
}

model DictationAttempt {
  id              String        @id @default(uuid())
  dictationId     String        @map("dictation_id")
  userId          String        @map("user_id")
  learningItemId  String?       @map("learning_item_id")
  originalText    String        @map("original_text")
  userInput       String        @map("user_input")
  accuracyScore   Float         @map("accuracy_score")
  levenshteinDist Int           @map("levenshtein_dist")
  timeSpent       Int           @map("time_spent")
  errorDetails    Json?         @default("[]") @map("error_details")
  createdAt       DateTime      @default(now()) @map("created_at")
  dictation       Dictation     @relation(fields: [dictationId], references: [id], onDelete: Cascade)
  learningItem    LearningItem? @relation(fields: [learningItemId], references: [id])
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dictationId])
  @@index([userId])
  @@map("dictation_attempts")
}

model UserProgress {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  itemId         String       @map("item_id")
  proficiency    Int          @default(0)
  nextReviewDate DateTime?    @map("next_review_date")
  reviewHistory  Json?        @default("[]") @map("review_history")
  lastReviewedAt DateTime     @default(now()) @map("last_reviewed_at")
  easeFactor     Float        @default(2.5)
  interval       Int          @default(0)
  repetition     Int          @default(0)
  item           LearningItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([nextReviewDate])
  @@map("user_progress")
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  status      String    @default("TODO")
  dueDate     DateTime?
  priority    String    @default("MEDIUM")
  userId      String
  resourceId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  resource    Resource? @relation(fields: [resourceId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@map("tasks")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  action    String
  count     Int      @default(1)
  date      DateTime @db.Date
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, action, date])
  @@map("activity_logs")
}

model Insight {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  content   String
  category  String   @default("Error")
  tags      String[] @default([])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("insights")
}

enum ResourceType {
  PDF
  YOUTUBE
  TEXT
  IMAGE
  AUDIO
  WEBSITE
}

enum ItemType {
  VOCABULARY
  GRAMMAR
  CONCEPT
  SENTENCE
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Language {
  ENGLISH
  VIETNAMESE
  JAPANESE
  KOREAN
  CHINESE
  FRENCH
  GERMAN
  SPANISH
}

// ===== FINANCE MODULE =====

model Transaction {
  id           String          @id @default(uuid())
  userId       String          @map("user_id")
  categoryId   String?         @map("category_id")
  amount       Float
  type         TransactionType
  note         String?
  date         DateTime        @default(now())
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category FinanceCategory?  @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([date])
  @@map("transactions")
}

model FinanceCategory {
  id           String          @id @default(uuid())
  userId       String          @map("user_id")
  name         String
  icon         String          @default("💰")
  color        String          @default("#6366f1")
  type         TransactionType
  createdAt    DateTime        @default(now()) @map("created_at")

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@index([userId])
  @@map("finance_categories")
}

model Budget {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  categoryId String   @map("category_id")
  amount     Float
  month      Int      // 1-12
  year       Int
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category FinanceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month, year])
  @@index([userId])
  @@map("budgets")
}

enum TransactionType {
  INCOME
  EXPENSE
}

// ===== LANGUAGE LEARNING MODULE EXTENSIONS =====

model Deck {
  id          String         @id @default(uuid())
  userId      String         @map("user_id")
  title       String
  description String?
  isPublic    Boolean        @default(false) @map("is_public")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       LearningItem[]

  @@index([userId])
  @@map("decks")
}

model Goal {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  title           String
  target          Int       
  currentProgress Int       @default(0) @map("current_progress")
  deadline        DateTime?
  status          String    @default("IN_PROGRESS") 
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("goals")
}

model DailyQuest {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  date        DateTime @db.Date 
  type        String   
  target      Int      
  progress    Int      @default(0)
  isCompleted Boolean  @default(false) @map("is_completed")
  xpReward    Int      @default(50) @map("xp_reward")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, type])
  @@map("daily_quests")
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  badgeId   String   @map("badge_id") 
  earnedAt  DateTime @default(now()) @map("earned_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Conversation {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  topic      String
  transcript Json     @default("[]") 
  score      Float?
  feedback   Json?    @default("{}") 
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("conversations")
}
